{
    "name": "TyPy Compiler",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--privileged",
        "--network=host"
    ],
    "mounts": [
        "source=${localEnv:HOME}/.ssh/id_ed25519,target=/root/.ssh/id_ed25519,type=bind"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "lldb.executable": "/usr/bin/lldb",
                "rust-analyzer.check.command": "clippy"
            },
            "extensions": [
                "fill-labs.dependi",
                "GitHub.copilot",
                "rust-lang.rust-analyzer",
                "shd101wyy.markdown-preview-enhanced",
                "tamasfe.even-better-toml",
                "vadimcn.vscode-lldb",
                "Anthropic.claude-code",
                "ms-python.python"
            ]
        }
    },
    "postCreateCommand": "bash scripts/install-hooks.sh"
}