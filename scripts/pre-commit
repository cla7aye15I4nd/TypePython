#!/bin/bash
# Pre-commit hook to run CI checks locally before committing

set -e

echo "Running pre-commit checks..."
echo ""

# Check if there are any staged files
if git diff --cached --quiet; then
    echo "No staged changes to commit"
    exit 0
fi

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print status
print_status() {
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✓${NC} $1 passed"
    else
        echo -e "${RED}✗${NC} $1 failed"
        exit 1
    fi
}

# 1. Check for ELF files
echo -e "${YELLOW}[1/5]${NC} Checking for ELF files..."
elf_files=$(git diff --cached --name-only --diff-filter=ACM | while read -r file; do
    if [ -f "$file" ] && file "$file" | grep -q "ELF"; then
        echo "$file"
    fi
done)
if [ -n "$elf_files" ]; then
    echo -e "${RED}✗${NC} ELF files detected in staged changes:"
    echo "$elf_files"
    echo "Please remove these files from the commit."
    exit 1
fi
print_status "No ELF files"
echo ""

# 2. Check formatting
echo -e "${YELLOW}[2/5]${NC} Checking code formatting..."
cargo fmt -- --check
print_status "Format check"
echo ""

# 2. Run clippy
echo -e "${YELLOW}[2/4]${NC} Running clippy linter..."
cargo clippy -- -D warnings
print_status "Clippy"
echo ""

# 3. Build the project
echo -e "${YELLOW}[3/4]${NC} Building project..."
cargo build
print_status "Build"
echo ""

# 4. Run tests
echo -e "${YELLOW}[4/4]${NC} Running tests..."
cargo test
print_status "Tests"
echo ""

echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
echo ""
